# Citation Faithfulness Verification System — env contract
# Real values are loaded for build-time agents via manage_keys.py (encrypted store).
# For the deployed Vercel app, set ANTHROPIC_API_KEY in Vercel project env vars.

# Required — Anthropic API (Sonnet faithfulness + Haiku extraction)
ANTHROPIC_API_KEY=

# Optional — Perplexity (Stage-1 citation resolution alternative to Haiku).
# If unset or failing, the pipeline uses Haiku.
PERPLEXITY_API_KEY=

# SEC EDGAR requires a descriptive User-Agent: "Name email"
SEC_USER_AGENT=Fable5 BuildDay joga@numici.com
